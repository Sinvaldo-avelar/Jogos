'use client';

import { useState, useEffect, useMemo } from 'react';

export default function Home() {
  const [jogosInput, setJogosInput] = useState(""); 
  const [jogosProcessados, setJogosProcessados] = useState([]);
  const [resultadoInput, setResultadoInput] = useState("");
  const [custoPorJogo, setCustoPorJogo] = useState(3.00); 
  const [premio14, setPremio14] = useState(1500.00);
  const [premio15, setPremio15] = useState(500000.00);
  const [mounted, setMounted] = useState(false);

  // NOVO: Estado para o Volante Interativo
  const [volanteSelecionados, setVolanteSelecionados] = useState([]);

  useEffect(() => {
    const salvos = localStorage.getItem('estrategia_jogos');
    const resultadoSalvo = localStorage.getItem('estrategia_resultado');
    const custoSalvo = localStorage.getItem('estrategia_custo');
    if (salvos) setJogosProcessados(JSON.parse(salvos));
    if (resultadoSalvo) setResultadoInput(resultadoSalvo);
    if (custoSalvo) setCustoPorJogo(parseFloat(custoSalvo));
    setMounted(true);
  }, []);

  useEffect(() => {
    if (mounted) {
      localStorage.setItem('estrategia_jogos', JSON.stringify(jogosProcessados));
      localStorage.setItem('estrategia_resultado', resultadoInput);
      localStorage.setItem('estrategia_custo', custoPorJogo.toString());
    }
  }, [jogosProcessados, resultadoInput, custoPorJogo, mounted]);

  // FUNÇÃO PARA CLICAR NO NÚMERO DO VOLANTE
  const toggleNumeroVolante = (n) => {
    if (volanteSelecionados.includes(n)) {
      setVolanteSelecionados(volanteSelecionados.filter(num => num !== n));
    } else if (volanteSelecionados.length < 15) {
      setVolanteSelecionados([...volanteSelecionados, n].sort((a, b) => a - b));
    }
  };

  const salvarJogoVolante = () => {
    if (volanteSelecionados.length === 15) {
      setJogosProcessados([volanteSelecionados, ...jogosProcessados]);
      setVolanteSelecionados([]); // Limpa o volante para o próximo
    }
  };

  const importarJogos = () => {
    const linhas = jogosInput.trim().split('\n');
    const novosJogos = linhas.map(linha => {
      return linha.trim().split(/\s+/).map(Number).filter(n => n > 0 && n <= 25);
    }).filter(j => j.length > 0);
    setJogosProcessados([...jogosProcessados, ...novosJogos]);
    setJogosInput(""); 
  };

  const deletarUmJogo = (indexParaRemover) => {
    setJogosProcessados(jogosProcessados.filter((_, idx) => idx !== indexParaRemover));
  };

  const limparSistema = () => {
    if(confirm("Deseja apagar TUDO?")) {
      setJogosInput("");
      setJogosProcessados([]);
      setResultadoInput("");
      setVolanteSelecionados([]);
      localStorage.clear();
    }
  };

  const dezenasSorteadas = useMemo(() => {
    return resultadoInput.trim().split(/\s+/).map(Number).filter(n => n > 0 && n <= 25);
  }, [resultadoInput]);

  const analise = useMemo(() => {
    const investimentoTotal = jogosProcessados.length * custoPorJogo;
    let totalPremios = 0;
    let cont14 = 0;
    let cont15 = 0;

    const lista = jogosProcessados.map((jogo, id) => {
      const acertos = jogo.filter(n => dezenasSorteadas.includes(n)).length;
      if (acertos === 11) totalPremios += 7;
      if (acertos === 12) totalPremios += 14;
      if (acertos === 13) totalPremios += 35;
      if (acertos === 14) { totalPremios += premio14; cont14++; }
      if (acertos === 15) { totalPremios += premio15; cont15++; }
      return { jogo, acertos, idOriginal: id };
    });

    const saldoFinal = totalPremios - investimentoTotal;
    return { lista, totalPremios, investimentoTotal, saldoFinal, cont14, cont15 };
  }, [jogosProcessados, dezenasSorteadas, custoPorJogo, premio14, premio15]);

  if (!mounted) return null;

  return (
    <div style={styles.container}>
      <header style={styles.header}>
        <div>
          <h1 style={{ margin: 0, color: '#0f172a', fontSize: '24px' }}>ESTRATÉGIA MATEMÁTICA PRO</h1>
          <p style={{ margin: 0, color: '#64748b', fontSize: '11px', fontWeight: 'bold' }}>GESTOR DE VOLANTES ILIMITADOS</p>
        </div>
        <button style={styles.btnDeleteAll} onClick={limparSistema}>LIMPAR TUDO</button>
      </header>

      <div style={styles.mainLayout}>
        <div style={styles.sidebar}>
          
          {/* NOVO: VOLANTE INTERATIVO */}
          <section style={styles.card}>
            <h3 style={styles.cardTitle}>1. VOLANTE VIRTUAL ({volanteSelecionados.length}/15)</h3>
            <div style={styles.volanteGrid}>
              {Array.from({ length: 25 }, (_, i) => i + 1).map(n => (
                <button 
                  key={n} 
                  onClick={() => toggleNumeroVolante(n)}
                  style={{
                    ...styles.volanteDezena,
                    backgroundColor: volanteSelecionados.includes(n) ? '#3b82f6' : '#f1f5f9',
                    color: volanteSelecionados.includes(n) ? 'white' : '#64748b',
                    borderColor: volanteSelecionados.includes(n) ? '#2563eb' : '#e2e8f0'
                  }}
                >
                  {String(n).padStart(2, '0')}
                </button>
              ))}
            </div>
            <button 
              disabled={volanteSelecionados.length !== 15}
              onClick={salvarJogoVolante}
              style={{
                ...styles.btnSalvarVolante,
                opacity: volanteSelecionados.length === 15 ? 1 : 0.5,
                cursor: volanteSelecionados.length === 15 ? 'pointer' : 'not-allowed'
              }}
            >
              {volanteSelecionados.length === 15 ? "SALVAR JOGO NO PAINEL" : `FALTAM ${15 - volanteSelecionados.length} NÚMEROS`}
            </button>
          </section>

          <section style={styles.card}>
            <h3 style={styles.cardTitle}>2. AJUSTE DE VALORES</h3>
            <div style={styles.inputRow}>
              <span>Custo Jogo:</span>
              <input type="number" step="0.01" style={styles.inputSmall} value={custoPorJogo} onChange={(e) => setCustoPorJogo(parseFloat(e.target.value) || 0)}/>
            </div>
            <div style={styles.inputRow}>
              <span>Prêmio 14 pts:</span>
              <input type="number" style={styles.inputSmall} value={premio14} onChange={(e) => setPremio14(parseFloat(e.target.value) || 0)}/>
            </div>
            <div style={styles.inputRow}>
              <span>Prêmio 15 pts:</span>
              <input type="number" style={styles.inputSmall} value={premio15} onChange={(e) => setPremio15(parseFloat(e.target.value) || 0)}/>
            </div>
          </section>

          <section style={styles.card}>
            <h3 style={styles.cardTitle}>3. ENTRADA (ILIMITADA)</h3>
            <textarea 
              style={styles.textarea}
              placeholder="Ou cole seus jogos aqui..."
              value={jogosInput}
              onChange={(e) => setJogosInput(e.target.value)}
            />
            <button style={styles.btnImportar} onClick={importarJogos}>IMPORTAR E SOMAR</button>
          </section>

          <section style={styles.card}>
            <h3 style={styles.cardTitle}>4. CONFERIDOR</h3>
            <input style={styles.inputResultado} placeholder="01 02 03..." value={resultadoInput} onChange={(e) => setResultadoInput(e.target.value)}/>
          </section>

          <section style={{ ...styles.card, borderTop: '5px solid #3b82f6', backgroundColor: '#eff6ff' }}>
            <h3 style={{ ...styles.cardTitle, color: '#1e40af' }}>5. RESUMO DA OPERAÇÃO</h3>
            <div style={styles.financeiroRow}><span>Investimento:</span><b>R$ {analise.investimentoTotal.toLocaleString('pt-br', {minimumFractionDigits: 2})}</b></div>
            <div style={styles.financeiroRow}><span>Total Prêmios:</span><b style={{color: '#15803d'}}>R$ {analise.totalPremios.toLocaleString('pt-br', {minimumFractionDigits: 2})}</b></div>
            
            {analise.cont14 > 0 && <div style={styles.tagAviso}>🎯 {analise.cont14}x prêmio de 14 pts!</div>}
            {analise.cont15 > 0 && <div style={styles.tagAvisoOuro}>🏆 {analise.cont15}x prêmio de 15 pts!</div>}

            <div style={{...styles.saldoBox, backgroundColor: analise.saldoFinal >= 0 ? '#dcfce7' : '#fee2e2'}}>
              <span style={{fontSize: '10px'}}>SALDO LÍQUIDO:</span>
              <div style={{fontSize: '20px', fontWeight: '900', color: analise.saldoFinal >= 0 ? '#15803d' : '#b91c1c'}}>
                R$ {analise.saldoFinal.toLocaleString('pt-br', {minimumFractionDigits: 2})}
              </div>
            </div>
          </section>
        </div>

        <div style={{ ...styles.card, flex: 1 }}>
          <h3 style={styles.cardTitle}>PAINEL DE ANÁLISE ({jogosProcessados.length} JOGOS)</h3>
          <div style={styles.grid}>
            {analise.lista.map((res, idx) => {
              const isWin = res.acertos >= 11;
              const isEpic = res.acertos >= 14;
              return (
                <div key={idx} style={{ 
                  ...styles.jogoBox, 
                  border: isEpic ? '2px solid #f59e0b' : (isWin ? '1px solid #22c55e' : '1px solid #f1f5f9'), 
                  backgroundColor: isEpic ? '#fffbeb' : (isWin ? '#f0fdf4' : '#fff') 
                }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '8px', alignItems: 'center' }}>
                    <small style={{ color: '#cbd5e1', fontSize: '10px' }}>#{idx + 1}</small>
                    <div style={{display: 'flex', gap: '5px', alignItems: 'center'}}>
                        <b style={{ color: isEpic ? '#d97706' : (isWin ? '#16a34a' : '#94a3b8'), fontSize: '11px' }}>{res.acertos} pts</b>
                        <button onClick={() => deletarUmJogo(idx)} style={styles.btnDeletarUm}>✕</button>
                    </div>
                  </div>
                  <div style={styles.dezenasRow}>
                    {res.jogo.map(n => (
                      <span key={n} style={{ 
                        ...styles.dezena, 
                        backgroundColor: dezenasSorteadas.includes(n) ? (isEpic ? '#f59e0b' : (isWin ? '#22c55e' : '#64748b')) : '#f8fafc',
                        color: dezenasSorteadas.includes(n) ? 'white' : '#94a3b8'
                      }}>{String(n).padStart(2, '0')}</span>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  );
}

